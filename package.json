{
  "name": "andromeda",
  "version": "0.1.0",
  "description": "A personal macOS browser shell built with Electron, React, TypeScript, and Vite.",
  "main": "dist/main/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "typecheck": "tsc --noEmit",
    "build": "pnpm typecheck && vite build && node scripts/build-electron.mjs",
    "start": "electron dist/main/main.cjs",
    "perf:browsers": "node scripts/browser-perf-compare.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "electron": "42.3.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
